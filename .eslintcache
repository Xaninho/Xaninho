ePostContainer>\r\n      <SinglePostWrapper>\r\n        <PostImage\r\n          src={singlePost.mainImage.asset.url}\r\n          alt={singlePost.title}\r\n        ></PostImage>\r\n        <SinglePostInfo>\r\n          <SinglePostTitle>{singlePost.title}</SinglePostTitle>\r\n          <SinglePostExcerpt>{singlePost.excerpt}</SinglePostExcerpt>\r\n          <SinglePostDate>{singlePost.publishedAt}</SinglePostDate>\r\n        </SinglePostInfo>\r\n        <BlockContentWrapper>\r\n          <div className=\"prose\">\r\n            <BlockContent\r\n              blocks={singlePost.body}\r\n              projectId=\"r99w5jgb\"\r\n              dataset=\"production\"\r\n            />\r\n          </div>\r\n        </BlockContentWrapper>\r\n      </SinglePostWrapper>\r\n    </SinglePostContainer>\r\n  );\r\n};\r\n\r\nexport default SinglePost;\r\n","C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\pages\\Post.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\blog\\SinglePost\\SinglePostElements.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\pages\\Projects.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\projects\\Projects\\index.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\projects\\Projects\\ProjectsElements.js",[],{"ruleId":"114","replacedBy":"115"},{"ruleId":"116","replacedBy":"117"},{"ruleId":"118","severity":1,"message":"119","line":53,"column":11,"nodeType":"120","endLine":53,"endColumn":30},{"ruleId":"121","severity":1,"message":"122","line":3,"column":10,"nodeType":"123","messageId":"124","endLine":3,"endColumn":20},{"ruleId":"121","severity":1,"message":"125","line":19,"column":24,"nodeType":"123","messageId":"124","endLine":19,"endColumn":39},{"ruleId":"121","severity":1,"message":"126","line":3,"column":18,"nodeType":"123","messageId":"124","endLine":3,"endColumn":23},{"ruleId":"121","severity":1,"message":"127","line":8
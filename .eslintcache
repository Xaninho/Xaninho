rCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"58"},{"filePath":"109","messages":"110","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"111","messages":"112","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"113","messages":"114","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\index.js",[],["115","116"],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\App.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\Home.js",[],["117","118"],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\SinglePost.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\Post.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\Project.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\NavBar.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\client.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\homescreen\\HeroSection\\index.js",["119"],"import React, { useState } from \"react\";\r\nimport Video from \"../../../assets/videos/herovideo.mp4\";\r\nimport PfPic from \"../../../assets/images/xaninho.jpg\";\r\nimport PDF from \"../../../assets/CV.pdf\";\r\n\r\nimport {\r\n  HeroContainer,\r\n  HeroBg,\r\n  VideoBg,\r\n  HeroContent,\r\n  HeroH1,\r\n  HeroP,\r\n  HeroBtnWrapper,\r\n  HeroImage,\r\n  HeroDescription,\r\n  Button,\r\n} from \"./HeroElements\";\r\n\r\nconst HeroSection = () => {\r\n  const [hover, setHover] = useState(false);\r\n\r\n  const onHover = () => {\r\n    setHover(!hover);\r\n  };\r\n\r\n  return (\r\n    <HeroContainer>\r\n      <HeroBg>\r\n        <VideoBg autoPlay loop muted src={Video} type=\"video.mp4\" />\r\n      </HeroBg>\r\n      <HeroContent>\r\n        <HeroDescription>\r\n          <HeroH1>Alexandre Neves</HeroH1>\r\n          <HeroP>\r\n            Name is Alexandre, but my friends call me Xaninho for short!\r\n            Currently focusing on learning Front-End Web Development. Love\r\n            exercise, mindfulness and anime.\r\n          </HeroP>\r\n          <HeroBtnWrapper>\r\n            <Button\r\n              onMouseEnter={onHover}\r\n              onMouseLeave={onHover}\r\n              primary=\"true\"\r\n              dark=\"true\"\r\n              href={PDF}\r\n              target=\"_blank\"\r\n              download\r\n            >\r\n              Download CV\r\n            </Button>\r\n          </HeroBtnWrapper>\r\n        </HeroDescription>\r\n        <HeroImage>\r\n          <img src={PfPic} />\r\n        </HeroImage>\r\n      </HeroContent>\r\n    </HeroContainer>\r\n  );\r\n};\r\n\r\nexport default HeroSection;\r\n","C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\homescreen\\Navbar\\index.js",["120","121"],"import React, { useState, useEffect } from \"react\";\r\nimport { FaBars } from \"react-icons/fa\";\r\nimport { SocialIcon } from \"react-social-icons\";\r\n\r\nimport {\r\n  Nav,\r\n  NavbarContainer,\r\n  NavbarLogo,\r\n  MobileIcon,\r\n  NavMenu,\r\n  NavItem,\r\n  NavLinks,\r\n  NavBtn,\r\n  NavBtnLink,\r\n} from \"./NavbarElements\";\r\nimport { animateScroll as scroll } from \"react-scroll\";\r\n\r\nconst Navbar = ({ toggle }) => {\r\n  const [scrollNav, setScrollNav] = useState(false);\r\n\r\n  const changeNav = () => {\r\n    if (window.scrollY >= 80) {\r\n      setScrollNav(true);\r\n    } else {\r\n      setScrollNav(false);\r\n    }\r\n  };\r\n\r\n  useEffect(() => {\r\n    window.addEventListener(\"scroll\", changeNav);\r\n  }, []);\r\n\r\n  const toggleHome = () => {\r\n    scroll.scrollToTop();\r\n  };\r\n\r\n  return (\r\n    <Nav scrollNav={scrollNav}>\r\n      <NavbarContainer>\r\n        <NavbarLogo to=\"/\" onClick={toggleHome} scrollNav={scrollNav}>\r\n          Xaninho\r\n        </NavbarLogo>\r\n        <MobileIcon onClick={toggle}>\r\n          <FaBars />\r\n        </MobileIcon>\r\n        <NavMenu>\r\n          <NavItem>\r\n            <NavLinks\r\n              to=\"blog\"\r\n              smooth={true}\r\n              duration={500}\r\n              spy={true}\r\n              exact=\"true\"\r\n              offset={-80}\r\n              scrollNav={scrollNav}\r\n            >\r\n              Blog\r\n            </NavLinks>\r\n          </NavItem>\r\n          <NavItem>\r\n            <NavLinks\r\n              to=\"projects\"\r\n              smooth={true}\r\n              duration={500}\r\n              spy={true}\r\n              exact=\"true\"\r\n              offset={-80}\r\n              scrollNav={scrollNav}\r\n            >\r\n              Projects\r\n            </NavLinks>\r\n          </NavItem>\r\n        </NavMenu>\r\n\r\n        <NavMenu>\r\n          <SocialIcon\r\n            url=\"https://www.linkedin.com/in/xaninho-dev\"\r\n            className=\"mr-4\"\r\n            target=\"_blank\"\r\n            fgColor=\"#fff\"\r\n            style={{ height: 35, width: 35 }}\r\n          />\r\n          <SocialIcon\r\n            url=\"https://github.com/Xaninho\"\r\n            className=\"mr-4\"\r\n            target=\"_blank\"\r\n            fgColor=\"#f5f5f5\"\r\n            bgColor=\"#353535\"\r\n            style={{ height: 35, width: 35 }}\r\n          />\r\n        </NavMenu>\r\n      </NavbarContainer>\r\n    </Nav>\r\n  );\r\n};\r\n\r\nexport default Navbar;\r\n","C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\homescreen\\Navbar\\NavbarElements.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\homescreen\\HeroSection\\HeroElements.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\homescreen\\Sidebar\\index.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\homescreen\\Sidebar\\SidebarElements.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\pages\\Home.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\homescreen\\LatestPosts\\index.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\homescreen\\LatestPosts\\LatestPostsElements.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\homescreen\\MainProjects\\index.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\homescreen\\MainProjects\\MainProjectsElements.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\homescreen\\Footer\\index.js",["122","123"],"import React from \"react\";\r\nimport {\r\n  FooterContainer,\r\n  FooterWrap,\r\n  FooterLinksContainer,\r\n  FooterLinksWrapper,\r\n  FooterLinkTitle,\r\n  FooterLink,\r\n  FooterLinkItems,\r\n  SocialMedia,\r\n  SocialMediaWrap,\r\n  SocialLogo,\r\n  WebsiteRights,\r\n  SocialIcons,\r\n  SocialIconLink,\r\n  FooterLinkScroll,\r\n  FooterLinkExternal,\r\n} from \"./FooterElements\";\r\nimport { FaLinkedin, FaGithub, FaTwitter } from \"react-icons/fa\";\r\nimport { animateScroll as scroll } from \"react-scroll\";\r\n\r\nconst Footer = () => {\r\n  const toggleHome = () => {\r\n    scroll.scrollToTop();\r\n  };\r\n\r\n  return (\r\n    <FooterContainer>\r\n      <FooterWrap>\r\n        <FooterLinksContainer>\r\n          <FooterLinksWrapper>\r\n            <FooterLinkItems>\r\n              <FooterLinkTitle>Website</FooterLinkTitle>\r\n              <FooterLinkScroll\r\n                onClick={toggleHome}\r\n                smooth={true}\r\n                duration={500}\r\n              >\r\n                About\r\n              </FooterLinkScroll>\r\n              <FooterLinkScroll to=\"discover\" smooth={true} duration={500}>\r\n                Posts\r\n              </FooterLinkScroll>\r\n              <FooterLinkScroll to=\"services\" smooth={true} duration={500}>\r\n                Projects\r\n              </FooterLinkScroll>\r\n            </FooterLinkItems>\r\n          </FooterLinksWrapper>\r\n\r\n          <FooterLinksWrapper>\r\n            <FooterLinkItems>\r\n              <FooterLinkTitle>Github</FooterLinkTitle>\r\n              <FooterLinkExternal\r\n                href=\"https://github.com/Xaninho\"\r\n                target=\"_blank\"\r\n              >\r\n                Xaninho\r\n              </FooterLinkExternal>\r\n              <FooterLinkExternal\r\n                href=\"https://github.com/Xaninho/Xaninho\"\r\n                target=\"_blank\"\r\n              >\r\n                Code\r\n              </FooterLinkExternal>\r\n              <FooterLinkExternal\r\n                href=\"https://github.com/Xaninho/Xaninho/pulls\"\r\n                target=\"_blank\"\r\n              >\r\n                Pull Requests\r\n              </FooterLinkExternal>\r\n              <FooterLinkExternal\r\n                href=\"https://github.com/Xaninho/Xaninho/wiki\"\r\n                target=\"_blank\"\r\n              >\r\n                Wiki\r\n              </FooterLinkExternal>\r\n            </FooterLinkItems>\r\n          </FooterLinksWrapper>\r\n\r\n          <FooterLinksWrapper>\r\n            <FooterLinkItems>\r\n              <FooterLinkTitle>Contacts</FooterLinkTitle>\r\n              <FooterLinkExternal\r\n                href=\"https://www.linkedin.com/in/xaninho-dev/\"\r\n                target=\"_blank\"\r\n              >\r\n                LinkedIn\r\n              </FooterLinkExternal>\r\n              <FooterLinkExternal\r\n                href=\"https://github.com/Xaninho\"\r\n                target=\"_blank\"\r\n              >\r\n                Github\r\n              </FooterLinkExternal>\r\n            </FooterLinkItems>\r\n          </FooterLinksWrapper>\r\n        </FooterLinksContainer>\r\n\r\n        <SocialMedia>\r\n          <SocialMediaWrap>\r\n            <SocialLogo to=\"/\" onClick={toggleHome}>\r\n              Xaninho\r\n            </SocialLogo>\r\n            <WebsiteRights>\r\n              Xaninho © {new Date().getFullYear()} All rights reserved.\r\n            </WebsiteRights>\r\n            <SocialIcons>\r\n              <SocialIconLink href=\"/\" target=\"_blank\" aria-label=\"LinkedIn\">\r\n                <FaLinkedin />\r\n              </SocialIconLink>\r\n              <SocialIconLink href=\"/\" target=\"_blank\" aria-label=\"Github\">\r\n                <FaGithub />\r\n              </SocialIconLink>\r\n            </SocialIcons>\r\n          </SocialMediaWrap>\r\n        </SocialMedia>\r\n      </FooterWrap>\r\n    </FooterContainer>\r\n  );\r\n};\r\n\r\nexport default Footer;\r\n","C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\homescreen\\Footer\\FooterElements.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\pages\\Blog.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\blog\\Posts\\Posts.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\blog\\Posts\\PostsElements.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\blog\\SinglePost\\index.js",["124"],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\pages\\Post.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\blog\\SinglePost\\SinglePostElements.js",[],{"ruleId":"125","replacedBy":"126"},{"ruleId":"127","replacedBy":"128"},{"ruleId":"125","replacedBy":"129"},{"ruleId":"127","replacedBy":"130"},{"ruleId":"131","severity":1,"message":"132","line":54,"column":11,"nodeType":"133","endLine":54,"endColumn":30},{"ruleId":"134","severity":1,"message":"135","line":13,"column":3,"nodeType":"136","messageId":"137","endLine":13,"endColumn":9},{"ruleId":"134","severity":1,"message":"138","line":14,"column":3,"n
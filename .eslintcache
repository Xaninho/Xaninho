Rules":"54"},"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\index.js",[],["109","110"],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\App.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\client.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\homescreen\\HeroSection\\index.js",["111"],"import React, { useState } from \"react\";\r\nimport Video from \"../../../assets/videos/herovideo.mp4\";\r\nimport PfPic from \"../../../assets/images/xaninho.jpg\";\r\nimport PDF from \"../../../assets/CV.pdf\";\r\n\r\nimport {\r\n  HeroContainer,\r\n  HeroBg,\r\n  VideoBg,\r\n  HeroContent,\r\n  HeroH1,\r\n  HeroP,\r\n  HeroBtnWrapper,\r\n  HeroImage,\r\n  HeroDescription,\r\n  Button,\r\n} from \"./HeroElements\";\r\n\r\nconst HeroSection = () => {\r\n  const [hover, setHover] = useState(false);\r\n\r\n  const onHover = () => {\r\n    setHover(!hover);\r\n  };\r\n\r\n  return (\r\n    <HeroContainer>\r\n      <HeroBg>\r\n        <VideoBg autoPlay loop muted src={Video} type=\"video.mp4\" />\r\n      </HeroBg>\r\n      <HeroContent>\r\n        <HeroDescription>\r\n          <HeroH1>Alexandre Neves</HeroH1>\r\n          <HeroP>\r\n            O nome é Alexandre, mas os meus amigos chamam-me Xaninho! Atualmente\r\n            um Full-Stack Developer. Adoro exercício, mindfulness e anime.\r\n          </HeroP>\r\n          <HeroBtnWrapper>\r\n            <Button\r\n              onMouseEnter={onHover}\r\n              onMouseLeave={onHover}\r\n              primary=\"true\"\r\n              dark=\"true\"\r\n              href={PDF}\r\n              target=\"_blank\"\r\n              download\r\n            >\r\n              Transferir CV\r\n            </Button>\r\n          </HeroBtnWrapper>\r\n        </HeroDescription>\r\n        <HeroImage>\r\n          <img src={PfPic} />\r\n        </HeroImage>\r\n      </HeroContent>\r\n    </HeroContainer>\r\n  );\r\n};\r\n\r\nexport default HeroSection;\r\n","C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\homescreen\\Navbar\\index.js",["112","113"],"import React, { useState, useEffect } from \"react\";\r\nimport { FaBars } from \"react-icons/fa\";\r\nimport { SocialIcon } from \"react-social-icons\";\r\n\r\nimport {\r\n  Nav,\r\n  NavbarContainer,\r\n  NavbarLogo,\r\n  MobileIcon,\r\n  NavMenu,\r\n  NavItem,\r\n  NavLinks,\r\n  NavLinksExternal,\r\n} from \"./NavbarElements\";\r\nimport { animateScroll as scroll } from \"react-scroll\";\r\n\r\nconst Navbar = ({ toggle, noTransparent }) => {\r\n  const [scrollNav, setScrollNav] = useState(false);\r\n  const [transparency, setTransparency] = useState(noTransparent);\r\n\r\n  const changeNav = () => {\r\n    if (window.scrollY >= 80) {\r\n      setScrollNav(true);\r\n    } else {\r\n      setScrollNav(false);\r\n    }\r\n  };\r\n\r\n  useEffect(() => {\r\n    window.addEventListener(\"scroll\", changeNav);\r\n  }, []);\r\n\r\n  const toggleHome = () => {\r\n    scroll.scrollToTop();\r\n  };\r\n\r\n  return (\r\n    <Nav\r\n      scrollNav={scrollNav}\r\n      transparency={transparency}\r\n      style={transparency ? { background: \"#f5f5f5\" } : {}}\r\n    >\r\n      <NavbarContainer>\r\n        <NavbarLogo\r\n          to=\"/\"\r\n          onClick={toggleHome}\r\n          scrollNav={scrollNav}\r\n          style={transparency ? { color: \"#353535\" } : {}}\r\n          transparency={transparency}\r\n        >\r\n          Alexandre\r\n        </NavbarLogo>\r\n        <MobileIcon onClick={toggle}>\r\n          <FaBars />\r\n        </MobileIcon>\r\n        <NavMenu>\r\n          <NavItem>\r\n            <NavLinks\r\n              to=\"/blog\"\r\n              exact=\"true\"\r\n              offset={-80}\r\n              scrollNav={scrollNav}\r\n              style={transparency ? { color: \"#353535\" } : {}}\r\n            >\r\n              Blog\r\n            </NavLinks>\r\n          </NavItem>\r\n          <NavItem>\r\n            <NavLinks\r\n              to=\"/projects\"\r\n              exact=\"true\"\r\n              offset={-80}\r\n              scrollNav={scrollNav}\r\n              style={transparency ? { color: \"#353535\" } : {}}\r\n            >\r\n              Projetos\r\n            </NavLinks>\r\n          </NavItem>\r\n        </NavMenu>\r\n\r\n        <NavMenu>\r\n          <NavItem>\r\n            <NavLinksExternal\r\n              href=\"https://www.linkedin.com/in/alexandre-hacker\"\r\n              target=\"_blank\"\r\n              offset={-80}\r\n              scrollNav={scrollNav}\r\n              style={transparency ? { color: \"#353535\" } : {}}\r\n            >\r\n              LinkedIn\r\n            </NavLinksExternal>\r\n          </NavItem>\r\n          <NavItem>\r\n            <NavLinksExternal\r\n              href=\"https://github.com/Xaninho\"\r\n              target=\"_blank\"\r\n              offset={-80}\r\n              scrollNav={scrollNav}\r\n              style={transparency ? { color: \"#353535\" } : {}}\r\n            >\r\n              Github\r\n            </NavLinksExternal>\r\n          </NavItem>\r\n        </NavMenu>\r\n\r\n        {/*<NavMenu scrollNav={scrollNav} transparency={transparency}>\r\n          <SocialIcon\r\n            url=\"https://www.linkedin.com/in/xaninho-dev\"\r\n            className=\"mr-4\"\r\n            target=\"_blank\"\r\n            fgColor={scrollNav ? \"#353535\" : \"#f5f5f5\"}\r\n            bgColor=\"transparent\"\r\n            style={{ height: 50, width: 50 }}\r\n          />\r\n          <SocialIcon\r\n            url=\"https://github.com/Xaninho\"\r\n            target=\"_blank\"\r\n            fgColor={scrollNav ? \"#353535\" : \"#f5f5f5\"}\r\n            bgColor=\"transparent\"\r\n            style={{ height: 50, width: 50 }}\r\n          />\r\n        </NavMenu>*/}\r\n      </NavbarContainer>\r\n    </Nav>\r\n  );\r\n};\r\n\r\nexport default Navbar;\r\n","C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\homescreen\\Navbar\\NavbarElements.js",["114"],"import styled from \"styled-components\";\r\nimport { Link as LinkR } from \"react-router-dom\";\r\nimport { Link as LinkS } from \"react-scroll\";\r\n\r\nexport const Nav = styled.nav`\r\n  background: ${({ scrollNav }) => (scrollNav ? \"#f5f5f5\" : \"transparent\")};\r\n  height: 80px;\r\n  margin-top: -80px;\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n  font-size: 1rem;\r\n  position: sticky;\r\n  top: 0;\r\n  z-index: 10;\r\n  transition: 0.8s all ease;\r\n`;\r\n\r\nexport const NavbarContainer = styled.div`\r\n  display: flex;\r\n  justify-content: space-between;\r\n  height: 80px;\r\n  z-index: 1;\r\n  width: 100%;\r\n  padding: 0 24px;\r\n  max-width: 1100px;\r\n`;\r\n\r\nexport const NavbarLogo = styled(LinkR)`\r\n  color: ${({ scrollNav }) => (scrollNav ? \"#343434\" : \"#f5f5f5\")};\r\n  justify-self: flex-start;\r\n  cursor: pointer;\r\n  font-size: 1.5rem;\r\n  display: flex;\r\n  align-items: center;\r\n  margin-left: 24px;\r\n  font-weight: bold;\r\n  text-decoration: none;\r\n  font-family: \"Philosopher\";\r\n  transition: 0.8s all ease;\r\n\r\n  &:hover {\r\n    color: #00b5ad;\r\n  }\r\n`;\r\n\r\nexport const MobileIcon = styled.div`\r\n  display: none;\r\n  @media screen and (max-width: 768px) {\r\n    display: block;\r\n    position: absolute;\r\n    top: 0;\r\n    right: 0;\r\n    margin-top: 10px;\r\n    transform: translate(-100%, 60%);\r\n    font-size: 1.8rem;\r\n    cursor: pointer;\r\n    color: #00b5ad;\r\n  }\r\n`;\r\n\r\nexport const NavMenu = styled.ul`\r\n  display: flex;\r\n  align-items: center;\r\n  list-style: none;\r\n  text-align: center;\r\n  transition: 0.8s all ease;\r\n  @media screen and (max-width: 768px) {\r\n    display: none;\r\n  }\r\n`;\r\n\r\nexport const NavItem = styled.li`\r\n  height: 80px;\r\n`;\r\n\r\nexport const NavLinks = styled(LinkR)`\r\n  height: 80px;\r\n  display: flex;\r\n  align-items: center;\r\n  text-decoration: none;\r\n  padding: 0 1rem;\r\n  height: 100%;\r\n  cursor: pointer;\r\n  color: ${({ scrollNav }) => (scrollNav ? \"#343434\" : \"#f5f5f5\")};\r\n  transition: 0.8s all ease;\r\n  &.active {\r\n    border-bottom: 3px solid #01bf71;\r\n  }\r\n  &:hover {\r\n    color: #00b5ad;\r\n  }\r\n`;\r\n\r\nexport const NavLinksExternal = styled.a`\r\n  height: 80px;\r\n  display: flex;\r\n  align-items: center;\r\n  text-decoration: none;\r\n  padding: 0 1rem;\r\n  height: 100%;\r\n  cursor: pointer;\r\n  color: ${({ scrollNav }) => (scrollNav ? \"#343434\" : \"#f5f5f5\")};\r\n  transition: 0.8s all ease;\r\n  &.active {\r\n    border-bottom: 3px solid #01bf71;\r\n  }\r\n  &:hover {\r\n    color: #00b5ad;\r\n  }\r\n`;\r\n","C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\homescreen\\HeroSection\\HeroElements.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\homescreen\\Sidebar\\index.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\homescreen\\Sidebar\\SidebarElements.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\pages\\Home.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\homescreen\\LatestPosts\\index.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\homescreen\\LatestPosts\\LatestPostsElements.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\homescreen\\MainProjects\\index.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\homescreen\\MainProjects\\MainProjectsElements.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\homescreen\\Footer\\index.js",["115","116"],"import React from \"react\";\r\nimport {\r\n  FooterContainer,\r\n  FooterWrap,\r\n  FooterLinksContainer,\r\n  FooterLinksWrapper,\r\n  FooterLinkTitle,\r\n  FooterLink,\r\n  FooterLinkItems,\r\n  SocialMedia,\r\n  SocialMediaWrap,\r\n  SocialLogo,\r\n  WebsiteRights,\r\n  SocialIcons,\r\n  SocialIconLink,\r\n  FooterLinkScroll,\r\n  FooterLinkExternal,\r\n} from \"./FooterElements\";\r\nimport { FaLinkedin, FaGithub, FaTwitter } from \"react-icons/fa\";\r\nimport { animateScroll as scroll } from \"react-scroll\";\r\n\r\nconst Footer = () => {\r\n  const toggleHome = () => {\r\n    scroll.scrollToTop();\r\n  };\r\n\r\n  return (\r\n    <FooterContainer>\r\n      <FooterWrap>\r\n        <FooterLinksContainer>\r\n          <FooterLinksWrapper>\r\n            <FooterLinkItems>\r\n              <FooterLinkTitle>Website</FooterLinkTitle>\r\n              <FooterLinkScroll to=\"/\">Início</FooterLinkScroll>\r\n              <FooterLinkScroll to=\"/blog\">Blog</FooterLinkScroll>\r\n              <FooterLinkScroll to=\"/projects\">Projetos</FooterLinkScroll>\r\n            </FooterLinkItems>\r\n          </FooterLinksWrapper>\r\n\r\n          <FooterLinksWrapper>\r\n            <FooterLinkItems>\r\n              <FooterLinkTitle>Github</FooterLinkTitle>\r\n              <FooterLinkExternal\r\n                href=\"https://github.com/Xaninho\"\r\n                target=\"_blank\"\r\n              >\r\n                Xaninho\r\n              </FooterLinkExternal>\r\n              <FooterLinkExternal\r\n                href=\"https://github.com/Xaninho/Xaninho\"\r\n                target=\"_blank\"\r\n              >\r\n                Code\r\n              </FooterLinkExternal>\r\n              <FooterLinkExternal\r\n                href=\"https://github.com/Xaninho/Xaninho/pulls\"\r\n                target=\"_blank\"\r\n              >\r\n                Pull Requests\r\n              </FooterLinkExternal>\r\n              <FooterLinkExternal\r\n                href=\"https://github.com/Xaninho/Xaninho/wiki\"\r\n                target=\"_blank\"\r\n              >\r\n                Wiki\r\n              </FooterLinkExternal>\r\n            </FooterLinkItems>\r\n          </FooterLinksWrapper>\r\n\r\n          <FooterLinksWrapper>\r\n            <FooterLinkItems>\r\n              <FooterLinkTitle>Contactos</FooterLinkTitle>\r\n              <FooterLinkExternal\r\n                href=\"https://www.linkedin.com/in/xaninho-dev/\"\r\n                target=\"_blank\"\r\n              >\r\n                LinkedIn\r\n              </FooterLinkExternal>\r\n              <FooterLinkExternal\r\n                href=\"https://github.com/Xaninho\"\r\n                target=\"_blank\"\r\n              >\r\n                Github\r\n              </FooterLinkExternal>\r\n            </FooterLinkItems>\r\n          </FooterLinksWrapper>\r\n        </FooterLinksContainer>\r\n\r\n        <SocialMedia>\r\n          <SocialMediaWrap>\r\n            <SocialLogo to=\"/\" onClick={toggleHome}>\r\n              Portfolio\r\n            </SocialLogo>\r\n            <WebsiteRights>\r\n              Alexandre Neves © {new Date().getFullYear()} All rights reserved.\r\n            </WebsiteRights>\r\n            <SocialIcons>\r\n              <SocialIconLink\r\n                href=\"https://www.linkedin.com/in/xaninho-dev/\"\r\n                target=\"_blank\"\r\n                aria-label=\"LinkedIn\"\r\n              >\r\n                <FaLinkedin />\r\n              </SocialIconLink>\r\n              <SocialIconLink\r\n                href=\"https://github.com/Xaninho\"\r\n                target=\"_blank\"\r\n                aria-label=\"Github\"\r\n              >\r\n                <FaGithub />\r\n              </SocialIconLink>\r\n            </SocialIcons>\r\n          </SocialMediaWrap>\r\n        </SocialMedia>\r\n      </FooterWrap>\r\n    </FooterContainer>\r\n  );\r\n};\r\n\r\nexport default Footer;\r\n","C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\homescreen\\Footer\\FooterElements.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\pages\\Blog.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\blog\\Posts\\Posts.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\blog\\Posts\\PostsElements.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\blog\\SinglePost\\index.js",["117"],"import React, { useEffect, useState } from \"react\";\r\nimport { useParams } from \"react-router-dom\";\r\nimport sanityClient from \"../../../client\";\r\nimport imageUrlBuilder from \"@sanity/image-url\";\r\nimport BlockContent from \"@sanity/block-content-to-react\";\r\nimport {\r\n  PostImage,\r\n  SinglePostContainer,\r\n  SinglePostWrapper,\r\n  SinglePostInfo,\r\n  SinglePostDate,\r\n  SinglePostExcerpt,\r\n  SinglePostTitle,\r\n  BlockContentWrapper,\r\n} from \"./SinglePostElements\";\r\n\r\nconst builder = imageUrlBuilder(sanityClient);\r\nfunction urlFor(source) {\r\n  return builder.image(source);\r\n}\r\n\r\nconst SinglePost = () => {\r\n  const [singlePost, setSinglePost] = useState(null);\r\n  const { slug } = useParams();\r\n\r\n  useEffect(() => {\r\n    sanityClient\r\n      .fetch(\r\n        `*[slug.current == \"${slug}\"]{\r\n            title,\r\n            _id,\r\n            slug,\r\n            excerpt,\r\n            publishedAt,\r\n            mainImage{\r\n                asset->{\r\n                    _id,\r\n                    url\r\n                }\r\n            },\r\n            body,\r\n            \"name\": author->name\r\n        }`\r\n      )\r\n      .then((data) => setSinglePost(data[0]))\r\n      .catch(console.error);\r\n  }, [slug]);\r\n\r\n  if (!singlePost) return <div>Loading...</div>;\r\n\r\n  return (\r\n    <SinglePostContainer>\r\n      <SinglePostWrapper>\r\n        <PostImage\r\n          src={singlePost.mainImage.asset.url}\r\n          alt={singlePost.title}\r\n        ></PostImage>\r\n        <SinglePostInfo>\r\n          <SinglePostTitle>{singlePost.title}</SinglePostTitle>\r\n          <SinglePostExcerpt>{singlePost.excerpt}</SinglePostExcerpt>\r\n          <SinglePostDate>{singlePost.publishedAt}</SinglePostDate>\r\n        </SinglePostInfo>\r\n        <BlockContentWrapper>\r\n          <div className=\"prose\">\r\n            <BlockContent\r\n              blocks={singlePost.body}\r\n              projectId=\"r99w5jgb\"\r\n              dataset=\"production\"\r\n            />\r\n          </div>\r\n        </BlockContentWrapper>\r\n      </SinglePostWrapper>\r\n    </SinglePostContainer>\r\n  );\r\n};\r\n\r\nexport default SinglePost;\r\n","C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\pages\\Post.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\blog\\SinglePost\\SinglePostElements.js",[],["118","119"],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\pages\\Projects.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\projects\\Projects\\index.js",[],"C:\\Users\\neves\\Documents\\Programming\\Web\\Portfolio\\src\\components\\projects\\Projects\\ProjectsElements.js",[],{"ruleId":"120","replacedBy":"121"},{"ruleId":"122","replacedBy":"123"},{"ruleId":"124","severity":1,"message":"125","line":53,"column":11,"nodeType":"126","endLine":53,"endColumn":30},{"ruleId":"127","severity":1,"message":"128","line":3,"column":10,"nodeType":"129","messageId":"130","endLine":3,"endColumn":20},{"ruleId":"127","severity":1,"message":"131","line":19,"column":24,"nodeType":"129","messageId":"130","endLine":19,"endColumn":39},{"ruleId":"127","severity":1,"message":"132","line":3,"column":18,"nodeType":"129","messageId":"130","endLine":3,"endColumn":23},{"ruleId":"127","severity":1,"message":"133","line":8,"column":3,"nodeType":"129","messageId":"130","endLine":8,"endColumn":13},{"ruleId":"127","severity":1,"message":"134","line":19,"column":32,"nodeType":"129","messageId":"130","endLine":19,"endColumn":41},{"ruleId":"127","severity":1,"message":"135","line":18,"column":10,"nodeType":"129","messageId":"130","endLine":18,"en